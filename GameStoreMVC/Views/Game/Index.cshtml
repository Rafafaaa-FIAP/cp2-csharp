@model IEnumerable<GameStoreMVC.Models.Game>

@{
    ViewData["Title"] = "Jogos";
}

<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Lista de Jogos</h2>
        <a asp-action="CadastrarJogo" class="btn btn-primary">
            Novo Jogo
        </a>
    </div>

    <div class="card shadow-lg border-0 p-4" style="border-radius: 18px;">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Nome</th>
                    <th>Descrição</th>
                    <th>Dificuldade</th>
                    <th class="text-end">Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var jogo in Model)
                {
                    <tr>
                        <td>@jogo.Nome</td>
                        <td>@jogo.Descricao</td>
                        <td>@jogo.Dificuldade</td>
                        <td class="text-end">

                            <a asp-action="EditarJogo" asp-route-id="@jogo.Id" class="btn btn-sm btn-warning">
                                Editar
                            </a>

                            <form asp-action="ExcluirJogo" asp-route-id="@jogo.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-danger"
                                        onclick="return confirm('Deseja excluir este jogo?');">
                                    Excluir
                                </button>
                            </form>

                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>