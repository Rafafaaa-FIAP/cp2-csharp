@model GameStoreMVC.Models.LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<div class="container d-flex justify-content-center align-items-center min-vh-100">
    <div class="card shadow-lg border-0 p-4" style="width: 100%; max-width: 450px; border-radius: 18px;">

        <div class="text-center mb-4">
            <h2 class="fw-bold">Entrar</h2>
            <p class="text-muted mb-0">Acesse sua conta da GameStore</p>
        </div>

        <form asp-action="Login" method="post">
            @Html.AntiForgeryToken()

            @if (ViewBag.Erro != null)
            {
                <div class="alert alert-danger small text-center">
                    @ViewBag.Erro
                </div>
            }

            <div class="form-floating mb-3">
                <input asp-for="Email" type="email" class="form-control" placeholder="E-mail" />
                <label asp-for="Email">E-mail</label>
            </div>

            <div class="form-floating mb-4">
                <input asp-for="Senha" type="password" class="form-control" placeholder="Senha" />
                <label asp-for="Senha">Senha</label>
            </div>

            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-primary btn-lg">
                    Entrar
                </button>

                <a asp-action="CriarConta" class="btn btn-outline-secondary">
                    Criar conta
                </a>
            </div>
        </form>
    </div>
</div>