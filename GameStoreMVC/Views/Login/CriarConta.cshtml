@model GameStoreMVC.Models.UsuarioViewModel

@{
    ViewData["Title"] = "Novo Usuário";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Cadastrar Novo Usuário</h4>
                </div>
                <div class="card-body">
                    <form asp-action="CriarConta" method="post">
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="form-floating mb-3">
                            <input asp-for="Nome" class="form-control" placeholder="Nome do usuário" />
                            <label asp-for="Nome"></label>
                            <span asp-validation-for="Nome" class="text-danger"></span>
                        </div>

                        <div class="form-floating mb-4">
                            <input asp-for="Email" type="email" class="form-control" placeholder="Email do usuário" />
                            <label asp-for="Email"></label>
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="form-floating mb-4">
                            <input asp-for="Senha" type="password" class="form-control" placeholder="Senha do usuário" />
                            <label asp-for="Senha"></label>
                            <span asp-validation-for="Senha" class="text-danger"></span>
                        </div>

                        <div class="form-floating mb-4">
                            <input asp-for="ConfirmacaoSenha" type="password" class="form-control" placeholder="Confirmacão de senha do usuário" />
                            <label asp-for="ConfirmacaoSenha"></label>
                            <span asp-validation-for="ConfirmacaoSenha" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg">Salvar Usuário</button>
                            <a asp-action="Index" class="btn text-secondary btn btn-warning">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

