@model GameStoreMVC.Models.UsuarioViewModel

@{
    ViewData["Title"] = "Criar Conta";
}

<div class="container d-flex justify-content-center align-items-center min-vh-100">
    <div class="card shadow-lg border-0 p-4" style="width: 100%; max-width: 450px; border-radius: 18px;">

        <div class="text-center mb-4">
            <h2 class="fw-bold">Criar Conta</h2>
            <p class="text-muted mb-0">Cadastre-se para acessar a GameStore</p>
        </div>

        <form asp-action="CriarConta" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-floating mb-3">
                <input asp-for="Nome" class="form-control" placeholder="Nome completo" />
                <label asp-for="Nome">Nome</label>
                <span asp-validation-for="Nome" class="text-danger small"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Email" type="email" class="form-control" placeholder="E-mail" />
                <label asp-for="Email">E-mail</label>
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Senha" type="password" class="form-control" placeholder="Senha" />
                <label asp-for="Senha">Senha</label>
                <span asp-validation-for="Senha" class="text-danger small"></span>
            </div>

            <div class="form-floating mb-4">
                <input asp-for="ConfirmacaoSenha" type="password" class="form-control" placeholder="Confirmar senha" />
                <label asp-for="ConfirmacaoSenha">Confirmar senha</label>
                <span asp-validation-for="ConfirmacaoSenha" class="text-danger small"></span>
            </div>

            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-primary btn-lg">
                    Criar Conta
                </button>

                <a asp-action="Login" class="btn btn-outline-secondary">
                    Já tenho conta
                </a>
            </div>
        </form>
    </div>
</div>

